root ::= "<think>" "\n" think-content "\n" "</think>" "\n" "\n" original-json-root
think-content ::= ( [^<] | "<" [^/] | "<" "/" [^t] | "<" "/" "t" [^h] | "<" "/" "t" "h" [^i] | "<" "/" "t" "h" "i" [^n] | "<" "/" "t" "h" "i" "n" [^k] | "<" "/" "t" "h" "i" "n" "k" [^>] )*
original-json-root ::= "{" space connections-kv "," space junctions-kv "," space component-params-kv "}" space
component-params-kv ::= "\"component_params\"" space ":" space component-params
component-params ::= "{" space component-params-mixers-kv "," space component-params-delays-kv "," space component-params-chambers-kv "," space component-params-filters-kv "}" space
component-params-filters ::= "[" space (component-params-filters-item ("," space component-params-filters-item)*)? "]" space
component-params-filters-item ::= "{" space component-params-filters-item-id-kv "," space component-params-filters-item-critical-particle-diameter-kv "}" space
component-params-filters-item-critical-particle-diameter-kv ::= "\"critical_particle_diameter\"" space ":" space number
decimal-part ::= [0-9]{1,16}
integral-part ::= [0] | [1-9] [0-9]{0,15}
number ::= ("-"? integral-part) ("." decimal-part)? ([eE] [-+]? integral-part)? space
component-params-filters-item-id-kv ::= "\"id\"" space ":" space component-params-filters-item-id
junctions-item-1-target-kv ::= "\"target\"" space ":" space junctions-item-1-target
component-params-delays-item-id ::= "\"" ("delay_" [0-9]+) "\"" space
junctions-item-1-source-1-kv ::= "\"source_1\"" space ":" space junctions-item-1-source-1
junctions-item-1-id ::= "\"" ("junction_" [0-9]+) "\"" space
junctions-item-0-target-2-kv ::= "\"target_2\"" space ":" space junctions-item-0-target-2
component-params-mixers-item-id-kv ::= "\"id\"" space ":" space component-params-mixers-item-id
junctions-item-0-target-1 ::= "\"" ((("outlet" | "mixer" | "delay" | "chamber" | "filter" | "junction") "_" [0-9]+ | "droplet_" [0-9]+ "_" ("continuous" | "dispersed"))) "\"" space
junctions-item-0-source-kv ::= "\"source\"" space ":" space junctions-item-0-source
component-params-chambers-item-dimensions ::= "{" space component-params-chambers-item-dimensions-length-kv "," space component-params-chambers-item-dimensions-width-kv "}" space
junctions-item-1-source-2 ::= "\"" ((("inlet" | "mixer" | "delay" | "chamber" | "droplet" | "junction") "_" [0-9]+ | "filter_" [0-9]+ "_" ("smaller" | "larger"))) "\"" space
junctions-item-0-id ::= "\"" ("junction_" [0-9]+) "\"" space
component-params-mixers-kv ::= "\"mixers\"" space ":" space component-params-mixers
junctions-item-1-target ::= "\"" ((("outlet" | "mixer" | "delay" | "chamber" | "filter" | "junction") "_" [0-9]+ | "droplet_" [0-9]+ "_" ("continuous" | "dispersed"))) "\"" space
junctions-item-0 ::= "{" space junctions-item-0-id-kv "," space junctions-item-0-type-kv "," space junctions-item-0-source-kv "," space junctions-item-0-target-1-kv "," space junctions-item-0-target-2-kv "}" space
junctions-item-0-type-kv ::= "\"type\"" space ":" space junctions-item-0-type
connections-item-source ::= "\"" ((("inlet" | "mixer" | "delay" | "chamber" | "droplet") "_" [0-9]+ | "filter_" [0-9]+ "_" ("smaller" | "larger"))) "\"" space
junctions-item-1-source-2-kv ::= "\"source_2\"" space ":" space junctions-item-1-source-2
component-params-chambers-item-dimensions-length ::= ([1-9] [0-9]{0,15}) space
junctions-item-1-id-kv ::= "\"id\"" space ":" space junctions-item-1-id
component-params-delays ::= "[" space (component-params-delays-item ("," space component-params-delays-item)*)? "]" space
connections-kv ::= "\"connections\"" space ":" space connections
connections-item ::= "{" space connections-item-source-kv "," space connections-item-target-kv "}" space
component-params-mixers-item ::= "{" space component-params-mixers-item-id-kv "," space component-params-mixers-item-num-turnings-kv "}" space
junctions-item-0-target-2 ::= "\"" ((("outlet" | "mixer" | "delay" | "chamber" | "filter" | "junction") "_" [0-9]+ | "droplet_" [0-9]+ "_" ("continuous" | "dispersed"))) "\"" space
connections-item-target ::= "\"" ((("outlet" | "mixer" | "delay" | "chamber" | "filter") "_" [0-9]+ | "droplet_" [0-9]+ "_" ("continuous" | "dispersed"))) "\"" space
component-params-filters-kv ::= "\"filters\"" space ":" space component-params-filters
connections-item-target-kv ::= "\"target\"" space ":" space connections-item-target
connections ::= "[" space (connections-item ("," space connections-item)*)? "]" space
space ::= | " " | "\n"{1,2} [ \t]{0,20}
junctions-item-0-source ::= "\"" ((("inlet" | "mixer" | "delay" | "chamber" | "droplet" | "junction") "_" [0-9]+ | "filter_" [0-9]+ "_" ("smaller" | "larger"))) "\"" space
component-params-chambers-item-dimensions-width-kv ::= "\"width\"" space ":" space component-params-chambers-item-dimensions-width
component-params-chambers-item ::= "{" space component-params-chambers-item-id-kv "," space component-params-chambers-item-dimensions-kv "}" space
connections-item-source-kv ::= "\"source\"" space ":" space connections-item-source
component-params-filters-item-id ::= "\"" ("filter_" [0-9]+) "\"" space
junctions-item ::= junctions-item-0 | junctions-item-1
junctions-item-0-type ::= ("\"T-junction\"" | "\"Y-junction\"") space
component-params-delays-item-num-turnings-kv ::= "\"num_turnings\"" space ":" space component-params-delays-item-num-turnings
junctions-item-1 ::= "{" space junctions-item-1-id-kv "," space junctions-item-1-type-kv "," space junctions-item-1-source-1-kv "," space junctions-item-1-source-2-kv "," space junctions-item-1-target-kv "}" space
junctions ::= "[" space (junctions-item ("," space junctions-item)*)? "]" space
junctions-item-0-id-kv ::= "\"id\"" space ":" space junctions-item-0-id
component-params-chambers-item-dimensions-length-kv ::= "\"length\"" space ":" space component-params-chambers-item-dimensions-length
junctions-item-1-type-kv ::= "\"type\"" space ":" space junctions-item-1-type
junctions-kv ::= "\"junctions\"" space ":" space junctions
component-params-mixers-item-id ::= "\"" ("mixer_" [0-9]+) "\"" space
component-params-mixers-item-num-turnings ::= ([1-9] [0-9]{0,15}) space
component-params-chambers-kv ::= "\"chambers\"" space ":" space component-params-chambers
component-params-mixers-item-num-turnings-kv ::= "\"num_turnings\"" space ":" space component-params-mixers-item-num-turnings
component-params-mixers ::= "[" space (component-params-mixers-item ("," space component-params-mixers-item)*)? "]" space
junctions-item-1-type ::= ("\"T-junction\"" | "\"Y-junction\"") space
component-params-delays-kv ::= "\"delays\"" space ":" space component-params-delays
junctions-item-0-target-1-kv ::= "\"target_1\"" space ":" space junctions-item-0-target-1
junctions-item-1-source-1 ::= "\"" ((("inlet" | "mixer" | "delay" | "chamber" | "droplet" | "junction") "_" [0-9]+ | "filter_" [0-9]+ "_" ("smaller" | "larger"))) "\"" space
component-params-chambers-item-id-kv ::= "\"id\"" space ":" space component-params-chambers-item-id
component-params-delays-item-id-kv ::= "\"id\"" space ":" space component-params-delays-item-id
component-params-delays-item-num-turnings ::= ([1-9] [0-9]{0,15}) space
component-params-delays-item ::= "{" space component-params-delays-item-id-kv "," space component-params-delays-item-num-turnings-kv "}" space
component-params-chambers ::= "[" space (component-params-chambers-item ("," space component-params-chambers-item)*)? "]" space
component-params-chambers-item-id ::= "\"" ("chamber_" [0-9]+) "\"" space
component-params-chambers-item-dimensions-width ::= ([1-9] [0-9]{0,15}) space
component-params-chambers-item-dimensions-kv ::= "\"dimensions\"" space ":" space component-params-chambers-item-dimensions